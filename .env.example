# Supabase project (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel password (single shared password for /admin)
ADMIN_PASSWORD=choose-a-strong-password

# Shop WhatsApp number in international format, no + or spaces
NEXT_PUBLIC_WHATSAPP_NUMBER=923239637000
